<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MonitoringSystem.Maui.App">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="Primary">#7F77DD</Color>
            <Color x:Key="PrimaryDark">#26215C</Color>
            <Color x:Key="Background">#0f1117</Color>
            <Color x:Key="Surface">#1a1d27</Color>
            <Color x:Key="TextPrimary">#e2e8f0</Color>
            <Color x:Key="TextMuted">#64748b</Color>
            <Color x:Key="Danger">#ef4444</Color>
            <Color x:Key="Success">#22c55e</Color>
        </ResourceDictionary>
    </Application.Resources>
</Application>
