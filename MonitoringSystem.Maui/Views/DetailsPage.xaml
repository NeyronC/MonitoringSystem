<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MonitoringSystem.Maui.Views.DetailsPage"
             Title="Live дані"
             BackgroundColor="#0a0c14">

    <Grid RowDefinitions="Auto,*">

        <!-- Таб-бар -->
        <Grid Grid.Row="0" ColumnDefinitions="*,*,*"
              BackgroundColor="#111827"
              Padding="12,8">
            <Button Grid.Column="0" x:Name="TabTabs"
                    Text="🌍 Вкладки"
                    Command="{Binding ShowTabsCommand}"
                    BackgroundColor="{Binding TabsTabColor}"
                    TextColor="White"
                    CornerRadius="8" HeightRequest="36"
                    FontSize="12" Margin="2,0"/>
            <Button Grid.Column="1" x:Name="TabProcs"
                    Text="⚙️ Процеси"
                    Command="{Binding ShowProcessesCommand}"
                    BackgroundColor="{Binding ProcsTabColor}"
                    TextColor="White"
                    CornerRadius="8" HeightRequest="36"
                    FontSize="12" Margin="2,0"/>
            <Button Grid.Column="2" x:Name="TabNet"
                    Text="🌐 Мережа"
                    Command="{Binding ShowNetworkCommand}"
                    BackgroundColor="{Binding NetTabColor}"
                    TextColor="White"
                    CornerRadius="8" HeightRequest="36"
                    FontSize="12" Margin="2,0"/>
        </Grid>

        <!-- Контент вкладок -->
        <Grid Grid.Row="1" Padding="12">

            <!-- Вкладки браузера -->
            <VerticalStackLayout IsVisible="{Binding ShowTabs}" Spacing="8">
                <Label Text="{Binding TabsHeader}"
                       FontSize="13" TextColor="#6b7280"
                       Margin="4,8,4,4"/>
                <CollectionView ItemsSource="{Binding ActiveTabs}">
                    <CollectionView.EmptyView>
                        <Label Text="Активних вкладок не знайдено.&#10;Переконайся що Chrome відкритий."
                               TextColor="#374151" FontSize="13"
                               HorizontalTextAlignment="Center"
                               Margin="0,40"/>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeShape="RoundRectangle 10"
                                    StrokeThickness="1" Stroke="#1e293b"
                                    BackgroundColor="#111827"
                                    Padding="14,11" Margin="0,3">
                                <Grid ColumnDefinitions="Auto,*">
                                    <Label Grid.Column="0" Text="🌍"
                                           FontSize="16" VerticalOptions="Center"
                                           Margin="0,0,10,0"/>
                                    <Label Grid.Column="1" Text="{Binding .}"
                                           FontSize="13" TextColor="#e2e8f0"
                                           VerticalOptions="Center"
                                           LineBreakMode="TailTruncation"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Процеси -->
            <VerticalStackLayout IsVisible="{Binding ShowProcesses}" Spacing="4">
                <Grid ColumnDefinitions="*,Auto" Margin="4,8,4,4">
                    <Label Grid.Column="0" Text="{Binding ProcessesHeader}"
                           FontSize="13" TextColor="#6b7280"
                           VerticalOptions="Center"/>
                    <Entry Grid.Column="1"
                           x:Name="ProcessFilter"
                           Placeholder="Пошук..."
                           Text="{Binding ProcessFilter}"
                           BackgroundColor="#1e293b"
                           TextColor="#e2e8f0"
                           PlaceholderColor="#4b5563"
                           WidthRequest="140"
                           FontSize="12"/>
                </Grid>
                <CollectionView ItemsSource="{Binding FilteredProcesses}">
                    <CollectionView.EmptyView>
                        <Label Text="Немає процесів" TextColor="#374151"
                               FontSize="13" HorizontalTextAlignment="Center" Margin="0,40"/>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeShape="RoundRectangle 8"
                                    StrokeThickness="1" Stroke="#1e293b"
                                    BackgroundColor="#111827"
                                    Padding="12,8" Margin="0,2">
                                <Grid ColumnDefinitions="Auto,*">
                                    <Label Grid.Column="0" Text="⚙️"
                                           FontSize="13" VerticalOptions="Center"
                                           Margin="0,0,8,0"/>
                                    <Label Grid.Column="1" Text="{Binding .}"
                                           FontSize="12" TextColor="#94a3b8"
                                           VerticalOptions="Center"
                                           LineBreakMode="TailTruncation"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Мережеві з'єднання -->
            <VerticalStackLayout IsVisible="{Binding ShowNetwork}" Spacing="8">
                <Label Text="{Binding NetworkHeader}"
                       FontSize="13" TextColor="#6b7280"
                       Margin="4,8,4,4"/>
                <CollectionView ItemsSource="{Binding ActiveConnections}">
                    <CollectionView.EmptyView>
                        <Label Text="Активних зовнішніх з'єднань не знайдено"
                               TextColor="#374151" FontSize="13"
                               HorizontalTextAlignment="Center" Margin="0,40"/>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeShape="RoundRectangle 10"
                                    StrokeThickness="1" Stroke="#1e293b"
                                    BackgroundColor="#111827"
                                    Padding="14,11" Margin="0,3">
                                <Grid ColumnDefinitions="Auto,*">
                                    <Label Grid.Column="0" Text="🌐"
                                           FontSize="16" VerticalOptions="Center"
                                           Margin="0,0,10,0"/>
                                    <Label Grid.Column="1" Text="{Binding .}"
                                           FontSize="13" TextColor="#e2e8f0"
                                           FontFamily="Courier"
                                           VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

        </Grid>
    </Grid>
</ContentPage>
