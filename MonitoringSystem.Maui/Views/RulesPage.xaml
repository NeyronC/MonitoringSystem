<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MonitoringSystem.Maui.Views.RulesPage"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*" Padding="12">

        <!-- Форма додавання -->
        <Border Grid.Row="0" Padding="14" Margin="0,0,0,10"
                StrokeShape="RoundRectangle 12" StrokeThickness="1"
                Stroke="{AppThemeBinding Light=#FAEEDA, Dark=#633806}">
            <VerticalStackLayout Spacing="10">

                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Правила моніторингу"
                           FontAttributes="Bold" FontSize="16"
                           VerticalOptions="Center"/>
                    <Button Grid.Column="1"
                            Text="{Binding ShowForm, Converter={StaticResource BoolToStringConverter},
                                ConverterParameter='Сховати|+ Нове правило'}"
                            Command="{Binding ToggleFormCommand}"
                            BackgroundColor="#7F77DD" TextColor="White"
                            CornerRadius="8" FontSize="13" HeightRequest="36"/>
                </Grid>

                <!-- Форма (показується тільки якщо ShowForm = true) -->
                <VerticalStackLayout Spacing="8" IsVisible="{Binding ShowForm}">
                    <Border StrokeShape="RoundRectangle 8" StrokeThickness="1">
                        <Entry Placeholder="Назва правила"
                               Text="{Binding NewName}" Margin="10,0" HeightRequest="44"/>
                    </Border>

                    <Picker Title="Тип правила"
                            ItemsSource="{Binding RuleTypes}"
                            SelectedItem="{Binding NewRuleType}"/>

                    <Border StrokeShape="RoundRectangle 8" StrokeThickness="1">
                        <Entry Placeholder="Значення (напр. facebook.com або ExportData)"
                               Text="{Binding NewValue}" Margin="10,0" HeightRequest="44"/>
                    </Border>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Picker Grid.Column="0" Title="Severity"
                                ItemsSource="{Binding Severities}"
                                SelectedItem="{Binding NewSeverity}"/>
                        <Picker Grid.Column="1" Title="Дія"
                                ItemsSource="{Binding Actions}"
                                SelectedItem="{Binding NewAction}"/>
                    </Grid>

                    <Button Text="Зберегти правило"
                            Command="{Binding SaveRuleCommand}"
                            BackgroundColor="#1D9E75" TextColor="White"
                            CornerRadius="8" HeightRequest="44"/>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Border>

        <!-- Список правил -->
        <RefreshView Grid.Row="1"
                     Command="{Binding RefreshCommand}"
                     IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Rules}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,4" Padding="12"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#F0F0F0, Dark=#444441}">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <VerticalStackLayout Grid.Column="0" Spacing="3">
                                    <Label Text="{Binding Name}"
                                           FontAttributes="Bold" FontSize="14"/>
                                    <HorizontalStackLayout Spacing="8">
                                        <Border BackgroundColor="#EEEDFE"
                                                StrokeShape="RoundRectangle 10"
                                                StrokeThickness="0" Padding="6,2">
                                            <Label Text="{Binding RuleType}"
                                                   FontSize="11" TextColor="#534AB7"/>
                                        </Border>
                                        <Label Text="{Binding Value}"
                                               FontSize="12" TextColor="Gray"/>
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="6">
                                        <Label Text="{Binding Severity}"
                                               FontSize="11" TextColor="#BA7517"/>
                                        <Label Text=" → "/>
                                        <Label Text="{Binding Action}"
                                               FontSize="11" TextColor="#185FA5"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <Button Grid.Column="1" Text="✕"
                                        Command="{Binding Source={RelativeSource
                                            AncestorType={x:Type ContentPage}},
                                            Path=BindingContext.DeleteRuleCommand}"
                                        CommandParameter="{Binding Id}"
                                        BackgroundColor="#FCEBEB" TextColor="#A32D2D"
                                        CornerRadius="8" WidthRequest="36"
                                        HeightRequest="36" Padding="0"
                                        VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
