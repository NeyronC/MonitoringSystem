<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MonitoringSystem.Maui.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F8F7FF, Dark=#1a1a2e}">

    <Grid RowDefinitions="*,Auto,*" Padding="32">
        <VerticalStackLayout Grid.Row="1" Spacing="16">

            <Label Text="🔐" FontSize="52" HorizontalTextAlignment="Center"/>
            <Label Text="Система моніторингу"
                   FontSize="22" FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light=#26215C, Dark=White}"/>
            <Label Text="Корпоративна мережа"
                   FontSize="13" HorizontalTextAlignment="Center"
                   TextColor="Gray" Margin="0,0,0,8"/>

            <!-- Поточний сервер + кнопка налаштування -->
            <Border x:Name="ServerPanel"
                    StrokeShape="RoundRectangle 8" StrokeThickness="1"
                    Stroke="#E0DEFF" BackgroundColor="#F0EEFF"
                    Padding="10,4">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0"
                           Text="{Binding ServerUrl}"
                           FontSize="12" TextColor="#26215C"
                           VerticalOptions="Center"/>
                    <Button Grid.Column="1"
                            Text="⚙️"
                            x:Name="SettingsButton"
                            Clicked="OnServerSettingsClicked"
                            BackgroundColor="Transparent"
                            TextColor="#7F77DD"
                            FontSize="18"
                            WidthRequest="44" HeightRequest="36"
                            Padding="0"/>
                </Grid>
            </Border>

            <Border StrokeShape="RoundRectangle 10" StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0DEFF, Dark=#3C3489}">
                <Entry Placeholder="Ім'я користувача"
                       Text="{Binding Username}"
                       Margin="14,0" HeightRequest="48"/>
            </Border>

            <Border StrokeShape="RoundRectangle 10" StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0DEFF, Dark=#3C3489}">
                <Entry Placeholder="Пароль" IsPassword="True"
                       Text="{Binding Password}"
                       Margin="14,0" HeightRequest="48"/>
            </Border>

            <Label Text="{Binding Error}"
                   TextColor="#E24B4A"
                   IsVisible="{Binding HasError}"
                   HorizontalTextAlignment="Center"
                   FontSize="13"/>

            <Button Text="Увійти"
                    x:Name="LoginButton"
                    Clicked="OnLoginClicked"
                    BackgroundColor="#7F77DD"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="50"
                    FontAttributes="Bold"/>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#7F77DD"
                               HorizontalOptions="Center"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
