<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:MonitoringSystem.Maui.Converters"
             x:Class="MonitoringSystem.Maui.Views.UsersPage"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*" Padding="12" RowSpacing="10">

        <!-- Панель управління -->
        <Border Grid.Row="0" Padding="14"
                StrokeShape="RoundRectangle 12" StrokeThickness="1"
                Stroke="{AppThemeBinding Light=#E0DEFF, Dark=#3C3489}">
            <VerticalStackLayout Spacing="10">

                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Управління юзерами"
                           FontAttributes="Bold" FontSize="16"
                           VerticalOptions="Center"/>
                    <Button Grid.Column="1"
                            Command="{Binding ToggleFormCommand}"
                            BackgroundColor="#7F77DD" TextColor="White"
                            CornerRadius="8" FontSize="13" HeightRequest="36">
                        <Button.Text>
                            <Binding Path="ShowForm">
                                <Binding.Converter>
                                    <converters:BoolToStringConverter/>
                                </Binding.Converter>
                                <Binding.ConverterParameter>Сховати|+ Новий юзер</Binding.ConverterParameter>
                            </Binding>
                        </Button.Text>
                    </Button>
                </Grid>

                <!-- Форма нового юзера -->
                <VerticalStackLayout Spacing="8" IsVisible="{Binding ShowForm}">

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 8"
                                StrokeThickness="1">
                            <Entry Placeholder="Логін"
                                   Text="{Binding NewUsername}"
                                   Margin="10,0" HeightRequest="44"/>
                        </Border>
                        <Border Grid.Column="1" StrokeShape="RoundRectangle 8"
                                StrokeThickness="1">
                            <Entry Placeholder="Пароль (мін. 6 символів)"
                                   IsPassword="True"
                                   Text="{Binding NewPassword}"
                                   Margin="10,0" HeightRequest="44"/>
                        </Border>
                    </Grid>

                    <Grid ColumnDefinitions="*,140" ColumnSpacing="8">
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 8"
                                StrokeThickness="1">
                            <Entry Placeholder="Відділ (напр. IT, HR, Sales)"
                                   Text="{Binding NewDepartment}"
                                   Margin="10,0" HeightRequest="44"/>
                        </Border>
                        <Picker Grid.Column="1"
                                Title="Роль"
                                ItemsSource="{Binding Roles}"
                                SelectedItem="{Binding NewRole}"/>
                    </Grid>

                    <Label Text="{Binding Error}"
                           TextColor="#E24B4A"
                           IsVisible="{Binding HasError}"
                           FontSize="12"/>

                    <Button Text="Створити юзера"
                            Command="{Binding CreateUserCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            BackgroundColor="#1D9E75" TextColor="White"
                            CornerRadius="8" HeightRequest="44"
                            FontAttributes="Bold"/>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </Border>

        <!-- Список юзерів -->
        <RefreshView Grid.Row="1"
                     Command="{Binding RefreshCommand}"
                     IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Users}">
                <CollectionView.EmptyView>
                    <Label Text="Юзерів не знайдено"
                           HorizontalTextAlignment="Center"
                           TextColor="Gray" Margin="0,40"/>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,4" Padding="12"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#EBEBEB, Dark=#3a3a3a}">

                            <Grid ColumnDefinitions="40,*,Auto" ColumnSpacing="10">

                                <!-- Аватар -->
                                <Border Grid.Column="0"
                                        BackgroundColor="#EEEDFE"
                                        StrokeShape="Ellipse"
                                        StrokeThickness="0"
                                        WidthRequest="36" HeightRequest="36"
                                        VerticalOptions="Center">
                                    <Label FontSize="15" FontAttributes="Bold"
                                           TextColor="#534AB7"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center">
                                        <Label.Text>
                                            <Binding Path="Username"
                                                     Converter="{StaticResource InitialsConverter}"/>
                                        </Label.Text>
                                    </Label>
                                </Border>

                                <!-- Інфо -->
                                <VerticalStackLayout Grid.Column="1" Spacing="3"
                                                     VerticalOptions="Center">
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding Username}"
                                               FontAttributes="Bold" FontSize="14"/>

                                        <!-- Бейдж ролі -->
                                        <Border StrokeShape="RoundRectangle 10"
                                                StrokeThickness="0" Padding="6,2">
                                            <Border.BackgroundColor>
                                                <Binding Path="Role"
                                                         Converter="{StaticResource RoleColorConverter}"/>
                                            </Border.BackgroundColor>
                                            <Label Text="{Binding Role}"
                                                   FontSize="10" FontAttributes="Bold"
                                                   TextColor="#534AB7"/>
                                        </Border>

                                        <!-- Онлайн індикатор -->
                                        <Ellipse WidthRequest="8" HeightRequest="8"
                                                 VerticalOptions="Center">
                                            <Ellipse.Fill>
                                                <Binding Path="IsOnline"
                                                         Converter="{StaticResource BoolToColorConverter}"
                                                         ConverterParameter="#22c55e,#d1d5db"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                    </HorizontalStackLayout>

                                    <Label Text="{Binding Department}"
                                           FontSize="12" TextColor="Gray"/>
                                </VerticalStackLayout>

                                <!-- Кнопки дій -->
                                <HorizontalStackLayout Grid.Column="2" Spacing="5"
                                                       VerticalOptions="Center">

                                    <!-- Підвищити до Admin -->
                                    <Button Text="↑ Admin" FontSize="11"
                                            HeightRequest="32" Padding="8,0"
                                            CornerRadius="8"
                                            BackgroundColor="#EEEDFE"
                                            TextColor="#534AB7"
                                            IsVisible="{Binding Role,
                                                Converter={StaticResource IsRoleConverter},
                                                ConverterParameter=User}"
                                            Command="{Binding Source={RelativeSource
                                                AncestorType={x:Type ContentPage}},
                                                Path=BindingContext.MakeAdminCommand}"
                                            CommandParameter="{Binding Id}"/>

                                    <!-- Понизити до User -->
                                    <Button Text="↓ User" FontSize="11"
                                            HeightRequest="32" Padding="8,0"
                                            CornerRadius="8"
                                            BackgroundColor="#FEF9ED"
                                            TextColor="#854F0B"
                                            IsVisible="{Binding Role,
                                                Converter={StaticResource IsRoleConverter},
                                                ConverterParameter=Admin}"
                                            Command="{Binding Source={RelativeSource
                                                AncestorType={x:Type ContentPage}},
                                                Path=BindingContext.MakeUserCommand}"
                                            CommandParameter="{Binding Id}"/>

                                    <!-- Видалити -->
                                    <Button Text="✕" FontSize="14"
                                            HeightRequest="32" WidthRequest="34"
                                            Padding="0" CornerRadius="8"
                                            BackgroundColor="#FCEBEB"
                                            TextColor="#A32D2D"
                                            Command="{Binding Source={RelativeSource
                                                AncestorType={x:Type ContentPage}},
                                                Path=BindingContext.DeleteUserCommand}"
                                            CommandParameter="{Binding Id}"/>
                                </HorizontalStackLayout>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>
