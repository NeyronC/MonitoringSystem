<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:MonitoringSystem.Maui.Views"
       x:Class="MonitoringSystem.Maui.AppShell"
       Shell.NavBarIsVisible="False">

    <!-- Логін — без nav bar і tab bar -->
    <ShellContent Title="Вхід"
                  ContentTemplate="{DataTemplate views:LoginPage}"
                  Route="LoginPage"
                  Shell.TabBarIsVisible="False"/>

    <!-- Агент — головне вікно після логіну -->
    <ShellContent Title="Моніторинг"
                  ContentTemplate="{DataTemplate views:AgentPage}"
                  Route="AgentPage"
                  Shell.TabBarIsVisible="False"/>
</Shell>
