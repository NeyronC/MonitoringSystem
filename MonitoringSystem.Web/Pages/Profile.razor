@page "/profile"
@using System.Net.Http.Json
@inject IHttpClientFactory ClientFactory
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject NavigationManager Nav

<PageTitle>Мій профіль — Моніторинг</PageTitle>

@if (!_authorized) { <div style="display:none"></div> }
else
{
<div class="page-header">
    <h1 class="page-title">Мій профіль</h1>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;max-width:900px;">

    <!-- Статистика -->
    <div>
        <div class="stats-grid" style="grid-template-columns:1fr 1fr;margin-bottom:1.25rem;">
            <div class="stat-card blue">
                <div class="stat-number">@totalActions</div>
                <div class="stat-label">Всього дій</div>
            </div>
            <div class="stat-card red">
                <div class="stat-number">@myViolations</div>
                <div class="stat-label">Порушень</div>
            </div>
        </div>

        <div class="section">
            <div class="section-header"><h2 class="section-title">📋 Остання активність</h2></div>
            @if (!recentLogs.Any())
            { <div style="padding:1.5rem;color:var(--text-muted);font-size:13px;text-align:center;">Немає даних</div> }
            else
            {
                <table class="data-table">
                    <thead><tr><th>Час</th><th>Дія</th><th>Деталі</th></tr></thead>
                    <tbody>
                        @foreach (var l in recentLogs.Take(15))
                        {
                            <tr>
                                <td class="text-muted small">@l.Timestamp.ToLocalTime().ToString("dd.MM HH:mm")</td>
                                <td><span class="badge badge-type">@l.Action</span></td>
                                <td class="text-muted small">@(l.Details.Length > 50 ? l.Details[..50]+"…" : l.Details)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <!-- Зміна пароля -->
    <div>
        <div class="section">
            <div class="section-header"><h2 class="section-title">🔑 Зміна пароля</h2></div>
            <div style="padding:1.25rem;display:flex;flex-direction:column;gap:1rem;">
                <div class="form-group">
                    <label>Поточний пароль</label>
                    <input type="password" @bind="currentPassword" class="filter-input"
                           style="width:100%;" placeholder="Введіть поточний пароль"/>
                </div>
                <div class="form-group">
                    <label>Новий пароль</label>
                    <input type="password" @bind="newPassword" class="filter-input"
                           style="width:100%;" placeholder="Мінімум 6 символів"/>
                </div>
                <div class="form-group">
                    <label>Підтвердження</label>
                    <input type="password" @bind="confirmPassword" class="filter-input"
                           style="width:100%;" placeholder="Повторіть новий пароль"/>
                </div>
                @if (!string.IsNullOrEmpty(pwError))
                { <div style="color:var(--red);font-size:12px;">⚠️ @pwError</div> }
                @if (!string.IsNullOrEmpty(pwSuccess))
                { <div style="color:var(--green);font-size:12px;">✅ @pwSuccess</div> }
                <button class="btn-primary" @onclick="ChangePassword"
                        disabled="@(currentPassword.Length < 1 || newPassword.Length < 6)">
                    Змінити пароль
                </button>
            </div>
        </div>

        <!-- Мої порушення -->
        @if (myViolationsList.Any())
        {
            <div class="section" style="margin-top:1.25rem;">
                <div class="section-header"><h2 class="section-title">🚨 Мої порушення</h2></div>
                <table class="data-table">
                    <thead><tr><th>Час</th><th>Правило</th><th>Рівень</th></tr></thead>
                    <tbody>
                        @foreach (var v in myViolationsList.Take(10))
                        {
                            <tr>
                                <td class="text-muted small">@v.OccurredAt.ToLocalTime().ToString("dd.MM HH:mm")</td>
                                <td>@v.RuleName</td>
                                <td><span class="badge badge-@v.Severity.ToLower()">@v.Severity</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

</div>
}

@code {
    private bool _authorized, _rendered;
    private string currentPassword = "", newPassword = "", confirmPassword = "";
    private string pwError = "", pwSuccess = "";
    private long totalActions;
    private int myViolations;
    private List<LogItem> recentLogs = new();
    private List<ViolItem> myViolationsList = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _rendered) return;
        _rendered = true;
        try
        {
            var token = await LocalStorage.GetItemAsStringAsync("auth_token");
            if (string.IsNullOrEmpty(token)) { Nav.NavigateTo("/login", forceLoad: false); return; }
            _authorized = true;
            StateHasChanged();
            await LoadData();
            StateHasChanged();
        }
        catch (Microsoft.JSInterop.JSDisconnectedException) { }
        catch (Exception) { }
    }

    private async Task LoadData()
    {
        try
        {
            var http = await GetHttp();
            var logs = await http.GetFromJsonAsync<List<LogItem>>(
                "api/activity/logs?page=1&pageSize=50") ?? new();
            recentLogs   = logs;
            totalActions = logs.Count;

            var viols = await http.GetFromJsonAsync<List<ViolItem>>(
                "api/rules/violations?pageSize=50") ?? new();
            myViolationsList = viols;
            myViolations     = viols.Count;
        }
        catch { }
    }

    private async Task ChangePassword()
    {
        pwError = ""; pwSuccess = "";
        if (newPassword != confirmPassword)   { pwError = "Паролі не співпадають"; return; }
        if (newPassword.Length < 6)           { pwError = "Мінімум 6 символів"; return; }
        if (newPassword == currentPassword)   { pwError = "Новий пароль = старому"; return; }

        var http = await GetHttp();
        var resp = await http.PostAsJsonAsync("api/auth/change-password", new
        {
            CurrentPassword = currentPassword,
            NewPassword     = newPassword
        });

        if (resp.IsSuccessStatusCode)
        {
            pwSuccess = "Пароль успішно змінено!";
            currentPassword = ""; newPassword = ""; confirmPassword = "";
        }
        else
        {
            var err = await resp.Content.ReadFromJsonAsync<Dictionary<string,string>>();
            pwError = err?.GetValueOrDefault("message") ?? "Помилка зміни пароля";
        }
        StateHasChanged();
    }

    private async Task<HttpClient> GetHttp()
    {
        var http  = ClientFactory.CreateClient("API");
        var token = await LocalStorage.GetItemAsStringAsync("auth_token");
        if (!string.IsNullOrEmpty(token))
            http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        return http;
    }

    class LogItem
    {
        public string Action { get; set; } = ""; public string Details { get; set; } = "";
        public DateTime Timestamp { get; set; }
    }
    class ViolItem
    {
        public string RuleName { get; set; } = ""; public string Severity { get; set; } = "";
        public DateTime OccurredAt { get; set; }   public bool IsAcknowledged { get; set; }
    }
}
